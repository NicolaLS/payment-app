export PAPP_RELEASE_BUNDLE_STORE_FILE="/Users/sus/scratch/android-release-papp/publish-key/papp-publish.jks"
export PAPP_RELEASE_BUNDLE_KEY_ALIAS="papp-publish-key"

export PAPP_RELEASE_APK_STORE_FILE="/Users/sus/scratch/android-release-papp/release-key/papp-signing.jks"
export PAPP_RELEASE_APK_KEY_ALIAS="papp-signing-key"

if ! command -v pass >/dev/null 2>&1; then
    echo "pass is required for Android release signing env vars" >&2
    return 0
fi

papp_signing_password="$(pass show papp-signing 2>/dev/null | sed -n '1p')"

if [ -z "$papp_signing_password" ]; then
    echo "pass entry papp-signing is required for Android release signing env vars" >&2
    return 0
fi

export PAPP_RELEASE_BUNDLE_STORE_PASSWORD="$papp_signing_password"
export PAPP_RELEASE_BUNDLE_KEY_PASSWORD="$papp_signing_password"
export PAPP_RELEASE_APK_STORE_PASSWORD="$papp_signing_password"
export PAPP_RELEASE_APK_KEY_PASSWORD="$papp_signing_password"

unset papp_signing_password
